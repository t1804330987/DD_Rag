<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dong.ddrag.assistant.mapper.AssistantMessageMapper">

    <resultMap id="assistantMessageEntityMap" type="com.dong.ddrag.assistant.model.entity.AssistantMessageEntity">
        <id property="id" column="id"/>
        <result property="sessionId" column="session_id"/>
        <result property="role" column="role"/>
        <result property="toolMode" column="tool_mode"/>
        <result property="groupId" column="group_id"/>
        <result property="content" column="content"/>
        <result property="structuredPayload" column="structured_payload"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.dong.ddrag.assistant.model.entity.AssistantMessageEntity"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        insert into assistant_messages (
            session_id,
            role,
            tool_mode,
            group_id,
            content,
            structured_payload,
            created_at
        )
        values (
            #{sessionId},
            #{role},
            #{toolMode},
            #{groupId},
            #{content},
            cast(#{structuredPayload} as jsonb),
            #{createdAt}
        )
    </insert>

    <select id="countBySessionId" resultType="java.lang.Long">
        select count(1)
        from assistant_messages
        where session_id = #{sessionId}
    </select>

    <select id="selectBySessionIdOrderByCreatedAt" resultMap="assistantMessageEntityMap">
        select id,
               session_id,
               role,
               tool_mode,
               group_id,
               content,
               structured_payload,
               created_at
        from assistant_messages
        where session_id = #{sessionId}
        order by created_at asc, id asc
    </select>

    <select id="selectRecentBySessionId" resultMap="assistantMessageEntityMap">
        select id,
               session_id,
               role,
               tool_mode,
               group_id,
               content,
               structured_payload,
               created_at
        from assistant_messages
        where session_id = #{sessionId}
        order by created_at desc, id desc
        limit #{limit}
    </select>

    <delete id="deleteBySessionId">
        delete from assistant_messages
        where session_id = #{sessionId}
    </delete>
</mapper>
